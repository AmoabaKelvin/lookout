# Lookout configuration (read as environment variables).
# On a server this is installed to /etc/lookout/lookout.env by install.sh.
# Durations are in SECONDS (plain integers).

# --- alerting destinations: set any number; alerts fan out to all configured ---
# GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXX/messages?key=...&token=...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=987654321
# WEBHOOK_URL=https://example.com/hooks/lookout   # generic: receives a JSON payload with all alert fields
# SMTP (email): set host, from, and to at minimum
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=lookout@example.com
# SMTP_TO=you@example.com,oncall@example.com   # comma-separated

# --- thresholds (percent, 0-100) ---
MEM_THRESHOLD=85
DISK_THRESHOLD=85

# --- sustained breach before alerting (seconds; 0 = fire immediately) ---
MEM_FOR=120
DISK_FOR=120

# --- timing (seconds) ---
COLLECTION_INTERVAL=30
RENOTIFY_AFTER=3600

# --- optional external heartbeat (e.g. a healthchecks.io ping URL) ---
# HEARTBEAT_URL=
# HEARTBEAT_INTERVAL=60

# --- metric sources (defaults are correct for Linux) ---
MEMINFO_PATH=/proc/meminfo
DISKINFO_PATH=/proc/mounts

# --- docker event monitoring (paused for now) ---
DOCKER_ENABLED=false
